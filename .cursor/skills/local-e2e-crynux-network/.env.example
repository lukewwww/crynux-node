# Copy this file to .env and fill all required values before running the skill.
# This example file must not contain real private keys.

# Required now (node)
NODE_PRIVATE_KEY=

# Relay build and runtime values
RELAY_REPO_PATH=
RELAY_DYM_PRIVATE_KEY=
RELAY_NEAR_PRIVATE_KEY=
RELAY_WITHDRAW_WITHDRAWAL_FEE_ADDRESS=
# Signature-authorized address for /v1/credits APIs (must match the signer address used by credits endpoints).
RELAY_CREDITS_ADDRESS=
RELAY_DAO_ADDRESS=
# Native token transfers to this address are recorded as task quota and used for task creation, no withdrawal allowed.
RELAY_BUY_QUOTA_ADDRESS=
# Native token transfers to this address are recorded as relay account balance for cross-chain transfer flow.
RELAY_BUY_TASK_FEE_ADDRESS=

# Relay wallet build and runtime values
RELAY_WALLET_REPO_PATH=
RELAY_WALLET_RELAY_API_PRIVATE_KEY=
RELAY_WALLET_ACCOUNT_PRIVATE_KEY=

# Bridge values
BRIDGE_PRIVATE_KEY=

# Bridge task validation values
BRIDGE_BASE_URL=http://localhost:8080
LLM_SUBMIT_PATH=/api/v1/tasks/llm
VLM_SUBMIT_PATH=/api/v1/tasks/vlm
TASK_STATUS_PATH_TEMPLATE=/api/v1/tasks/%s
